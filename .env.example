# GEMINI_API_KEY: Required for Gemini AI API calls.

# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TMDB_API_KEY: v3 Key or v4 Read Access Token from The Movie Database (developer.themoviedb.org)
TMDB_API_KEY=""

# APP_URL: The URL where this applet is hosted.

# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/cinestream)
MONGODB_URI=""

# CLOUDINARY CONFIGURATION: For Phase 3 asset uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
